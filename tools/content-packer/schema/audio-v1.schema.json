{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cncweb.invalid/schema/audio-v1.schema.json",
  "title": "C&C Web browser-native audio index v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "version", "encoding", "assets", "diagnostics"],
  "properties": {
    "format": { "const": "cncweb-audio" },
    "version": { "const": 1 },
    "encoding": { "const": "wav-pcm" },
    "assets": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "items": { "$ref": "#/$defs/asset" }
    },
    "diagnostics": { "$ref": "#/$defs/diagnostics" }
  },
  "$defs": {
    "eventName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 16,
      "pattern": "^[A-Z0-9]+(?:\\.V0[0-3])?$"
    },
    "sourceName": {
      "type": "string",
      "minLength": 5,
      "maxLength": 16,
      "pattern": "^[A-Z0-9]+(?:\\.AUD|\\.V0[0-3])$"
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "eventName",
        "eventIds",
        "path",
        "sourceArchive",
        "sourceName",
        "sourceCompression",
        "sampleRate",
        "channels",
        "bitsPerSample",
        "frames",
        "sha256"
      ],
      "properties": {
        "kind": { "enum": ["sound", "speech"] },
        "eventName": { "$ref": "#/$defs/eventName" },
        "eventIds": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "uniqueItems": true,
          "items": { "type": "integer", "minimum": 0, "maximum": 65535 }
        },
        "path": {
          "type": "string",
          "pattern": "^audio/(?:sfx|speech)/[a-z0-9]+(?:\\.v0[0-3])?\\.wav$"
        },
        "sourceArchive": { "enum": ["SPEECH.MIX", "SOUNDS.MIX"] },
        "sourceName": { "$ref": "#/$defs/sourceName" },
        "sourceCompression": { "enum": [0, 1, 99] },
        "sampleRate": { "type": "integer", "minimum": 4000, "maximum": 192000 },
        "channels": { "enum": [1, 2] },
        "bitsPerSample": { "enum": [8, 16] },
        "frames": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "failure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "eventName", "sourceArchive", "sourceName", "reason"],
      "properties": {
        "kind": { "enum": ["sound", "speech"] },
        "eventName": { "$ref": "#/$defs/eventName" },
        "sourceArchive": { "enum": ["SPEECH.MIX", "SOUNDS.MIX"] },
        "sourceName": { "$ref": "#/$defs/sourceName" },
        "reason": { "type": "string", "minLength": 1, "maxLength": 1024 }
      }
    },
    "diagnostics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidateCount", "missingCandidates", "decodeFailures"],
      "properties": {
        "candidateCount": { "type": "integer", "minimum": 1, "maximum": 1000 },
        "missingCandidates": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "decodeFailures": {
          "type": "array",
          "maxItems": 1000,
          "items": { "$ref": "#/$defs/failure" }
        }
      }
    }
  }
}
