{
  "name": "theater-runtime-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "check:bundle-budget": "node scripts/check-bundle-budget.mjs",
    "check:bundle-budget:integrated": "node scripts/check-bundle-budget.mjs --require-engine",
    "preview": "vite preview",
    "test": "vitest run",
    "test:bundle-budget": "node --test scripts/test-bundle-budget.mjs",
    "test:e2e": "pnpm build && playwright test --grep-invert @performance",
    "test:performance": "pnpm build && playwright test e2e/performance.spec.ts --repeat-each=2",
    "test:classic-freeware": "CNCWEB_CLASSIC_FREEWARE_PREFLIGHT=1 playwright test e2e/classic-freeware.preflight.spec.ts",
    "test:classic-freeware:genuine-victory": "CNCWEB_CLASSIC_FREEWARE_GENUINE_VICTORY=1 playwright test e2e/classic-freeware.genuine-victory.spec.ts",
    "test:classic-freeware:genuine-mission-two": "CNCWEB_CLASSIC_FREEWARE_GENUINE_MISSION_TWO=1 playwright test e2e/classic-freeware.genuine-victory.spec.ts",
    "test:classic-freeware:performance": "CNCWEB_CLASSIC_FREEWARE_PERFORMANCE=1 playwright test e2e/classic-freeware.performance.spec.ts",
    "test:classic-freeware:matrix": "node scripts/run-classic-freeware-matrix.mjs",
    "test:classic-freeware:deployment-tools": "node --test scripts/test-classic-freeware-base-url.mjs scripts/test-classic-freeware-deployment.mjs",
    "test:classic-freeware:release": "pnpm test:classic-freeware:performance && pnpm verify:classic-freeware:mission-one && pnpm verify:classic-freeware:mission-two && pnpm verify:classic-freeware:mission-three && pnpm verify:classic-freeware:mission-four && pnpm verify:classic-freeware:mission-five && pnpm test:classic-freeware && pnpm test:classic-freeware:matrix",
    "test:classic-freeware:staging": "node scripts/run-classic-freeware-staging.mjs",
    "verify:classic-freeware:mission-one": "node scripts/verify-classic-freeware-mission-one.mjs",
    "verify:classic-freeware:mission-two": "CNCWEB_VERIFY_MISSION=2 node scripts/verify-classic-freeware-mission-one.mjs",
    "verify:classic-freeware:mission-three": "CNCWEB_VERIFY_MISSION=3 node scripts/verify-classic-freeware-mission-one.mjs",
    "verify:classic-freeware:mission-four": "pnpm verify:classic-freeware:mission-four:west-a && pnpm verify:classic-freeware:mission-four:west-b && pnpm verify:classic-freeware:mission-four:east-a",
    "verify:classic-freeware:mission-four:west-a": "CNCWEB_VERIFY_MISSION=4 CNCWEB_VERIFY_MISSION_VARIANT=west-a node scripts/verify-classic-freeware-mission-one.mjs",
    "verify:classic-freeware:mission-four:west-b": "CNCWEB_VERIFY_MISSION=4 CNCWEB_VERIFY_MISSION_VARIANT=west-b node scripts/verify-classic-freeware-mission-one.mjs",
    "verify:classic-freeware:mission-four:east-a": "CNCWEB_VERIFY_MISSION=4 CNCWEB_VERIFY_MISSION_VARIANT=east-a node scripts/verify-classic-freeware-mission-one.mjs",
    "verify:classic-freeware:mission-five": "pnpm verify:classic-freeware:mission-five:east-a && pnpm verify:classic-freeware:mission-five:west-a && pnpm verify:classic-freeware:mission-five:west-b",
    "verify:classic-freeware:mission-five:east-a": "CNCWEB_VERIFY_MISSION=5 CNCWEB_VERIFY_MISSION_VARIANT=east-a node scripts/verify-classic-freeware-mission-one.mjs",
    "verify:classic-freeware:mission-five:west-a": "CNCWEB_VERIFY_MISSION=5 CNCWEB_VERIFY_MISSION_VARIANT=west-a node scripts/verify-classic-freeware-mission-one.mjs",
    "verify:classic-freeware:mission-five:west-b": "CNCWEB_VERIFY_MISSION=5 CNCWEB_VERIFY_MISSION_VARIANT=west-b node scripts/verify-classic-freeware-mission-one.mjs",
    "verify:classic-freeware:deployment": "node scripts/verify-classic-freeware-deployment.mjs",
    "test:owned-preflight-config": "node --test scripts/test-owned-browser-preflight-env.mjs && env -u CNCWEB_OWNED_BROWSER_PREFLIGHT playwright test --config playwright.owned.config.mjs",
    "test:watch": "vitest",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@zip.js/zip.js": "2.8.26",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/node": "24.13.3",
    "@vitejs/plugin-react": "6.0.3",
    "@playwright/test": "1.61.1",
    "jsdom": "29.1.1",
    "typescript": "5.9.3",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
