{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cncweb.invalid/schema/runtime-catalog-v1.schema.json",
  "title": "C&C Web runtime catalog v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "version", "engine", "engineRoot", "missions"],
  "properties": {
    "format": { "const": "cncweb-runtime" },
    "version": { "const": 1 },
    "engine": { "const": "tiberian-dawn" },
    "engineRoot": { "const": "engine/td" },
    "missions": { "type": "array" }
  },
  "oneOf": [
    {
      "title": "Generalized catalog",
      "properties": {
        "missions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/mission" }
        }
      }
    },
    {
      "title": "Legacy GDI mission 1 catalog",
      "properties": {
        "missions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "prefixItems": [{ "$ref": "#/$defs/legacyGdiMissionOne" }],
          "items": false
        }
      }
    }
  ],
  "$defs": {
    "briefing": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096,
      "pattern": "^[^\\r@\\u0000]+$"
    },
    "mission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "scenarioRoot",
        "scenario",
        "variation",
        "direction",
        "buildLevel",
        "sabotagedStructure",
        "faction",
        "title",
        "briefing",
        "theater"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"
        },
        "scenarioRoot": {
          "type": "string",
          "pattern": "^SC[GB][0-9]{2,3}[EW][A-DL]$"
        },
        "scenario": { "type": "integer", "minimum": 1, "maximum": 999 },
        "variation": { "enum": [0, 1, 2, 3, 5] },
        "direction": { "type": "integer", "minimum": 0, "maximum": 1 },
        "buildLevel": { "type": "integer", "minimum": 0, "maximum": 255 },
        "sabotagedStructure": { "type": "integer", "minimum": -1, "maximum": 255 },
        "faction": { "enum": ["gdi", "nod"] },
        "title": { "type": "string", "minLength": 1, "maxLength": 128 },
        "briefing": { "$ref": "#/$defs/briefing" },
        "theater": { "enum": ["temperate", "desert", "winter"] }
      }
    },
    "legacyGdiMissionOne": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "scenario",
        "variation",
        "direction",
        "buildLevel",
        "sabotagedStructure",
        "faction",
        "title",
        "briefing"
      ],
      "properties": {
        "id": { "const": "gdi-01-east-a" },
        "scenario": { "const": 1 },
        "variation": { "const": 0 },
        "direction": { "const": 0 },
        "buildLevel": { "const": 1 },
        "sabotagedStructure": { "const": -1 },
        "faction": { "const": "gdi" },
        "title": { "const": "GDI Mission 1" },
        "briefing": { "$ref": "#/$defs/briefing" }
      }
    }
  }
}
